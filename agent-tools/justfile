#!/usr/bin/env -S just --justfile
# List all available steps
default:
    @just --list

install-tmux:
    brew install tmux

install-tmupx:
    uv tool install tmuxp

# Start tmux with multiple claude code agents.
# AGENT_START_DIR pins the panes' working directory to where `just` was invoked from
# (invocation_directory), not the justfile directory.
start-agents:
    AGENT_START_DIR="{{invocation_directory()}}" tmuxp load {{justfile_directory()}}/claude-code-multi.yaml